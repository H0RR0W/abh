generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model StaffUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("inspector")
  districts String   @default("[]")
  createdAt DateTime @default(now())
}

model Migrant {
  id                 String   @id
  firstName          String
  lastName           String
  middleName         String   @default("")
  citizenship        String
  passportNumber     String
  passportSeries     String?
  passportIssuedBy   String?
  passportIssueDate  String?
  passportExpiry     String?
  phone              String
  birthDate          String
  status             String   @default("active")
  registrationDate   String
  registrationExpiry String
  employed           Boolean  @default(false)
  employer           String?
  photo              String?
  selfiePhoto        String?
  identityStatus     String   @default("unverified")
  address            String
  district           String   @default("Сухумский")
  violations         Int      @default(0)
  lat                Float
  lng                Float
  lastSeen           DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  documents       Document[]
  payments        Payment[]
  locationHistory LocationHistory[]
  chatMessages    ChatMessage[]
  inspections     Inspection[]
  violations2     Violation[]
}

model Document {
  id         String   @id @default(cuid())
  migrantId  String
  type       String
  name       String
  status     String   @default("pending")
  filePath   String?
  uploadedAt DateTime @default(now())

  migrant Migrant @relation(fields: [migrantId], references: [id], onDelete: Cascade)
}

model Payment {
  id          String @id @default(cuid())
  migrantId   String
  type        String
  amount      Int
  currency    String @default("RUB")
  date        String
  status      String
  description String

  migrant Migrant @relation(fields: [migrantId], references: [id], onDelete: Cascade)
}

model LocationHistory {
  id        String   @id @default(cuid())
  migrantId String
  lat       Float
  lng       Float
  timestamp DateTime
  address   String

  migrant Migrant @relation(fields: [migrantId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  migrantId String
  from      String
  text      String
  createdAt DateTime @default(now())

  migrant Migrant @relation(fields: [migrantId], references: [id], onDelete: Cascade)
}

model SmsCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
}

model Inspection {
  id         String   @id @default(cuid())
  migrantId  String
  type       String
  date       String
  inspector  String
  note       String   @default("")
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  migrant Migrant @relation(fields: [migrantId], references: [id], onDelete: Cascade)
}

model Violation {
  id          String   @id @default(cuid())
  migrantId   String
  type        String
  description String   @default("")
  severity    String   @default("medium")
  date        String
  fine        Int      @default(0)
  fineStatus  String   @default("unpaid")
  createdAt   DateTime @default(now())

  migrant Migrant @relation(fields: [migrantId], references: [id], onDelete: Cascade)
}
